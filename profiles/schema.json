{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FullPhysicsC Benchmark Profile",
  "type": "object",
  "required": ["name", "command"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "runs": {
      "type": "integer",
      "minimum": 1
    },
    "command": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        {
          "type": "object",
          "properties": {
            "windows": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "linux": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "macos": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "default": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
